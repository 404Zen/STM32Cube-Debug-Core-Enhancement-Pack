{
    // 使用 IntelliSense 了解相关属性。 
    // 悬停以查看现有属性的描述。
    // 欲了解更多信息，请访问: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [

        {
            "type": "jlinkgdbtarget",
            "request": "launch",
            "name": "JLink GDB Server",
            "origin": "snippet",
            "cwd": "${workspaceFolder}",
            "preBuild": "${command:st-stm32-ide-debug-launch.build}",
            "serverSpeed": "4000",
            "runEntry": "main",
            "numberDisplayMode": "dec",
            "serverReset": "Type 2: ResetPin",
            // "serverStartupDelay": 200,
            // "serverExe": "gdbserver",
            "verbose": false,
            "preRunCommands": [
                // reset clr MemMangement Fault
                "printf \"Reset MCU after download\\n\"",
                "monitor reset",
                "monitor sleep 100"
                ],
            "imagesAndSymbols": [
                
                {
                    // boot
                    // Do not flash boot image, only load symbols for debug
                    "imageFileName": "${workspaceFolder}/../boot/build/Debug/boot.elf",
                    // "symbolFileName": "${workspaceFolder}/../boot/build/Debug/boot.elf",
                    "symbolLoadAddress": "0x08000000"
                },
                {
                    "imageFileName": "${command:st-stm32-ide-debug-launch.get-projects-binary-from-context1}",
                    // app
                    // "imageFileName": "${workspaceFolder}/../app/build/Debug/app.elf",
                    "symbolLoadAddress": "0x90000000"
                },
            ],
        }
    ]
}
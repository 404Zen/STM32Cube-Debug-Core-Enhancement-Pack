+        await vscode.commands.executeCommand("setContext", "stm32cube-ide-reset.JLinkResetting", true);
+        try {
+            await session.customRequest("adapter/resetTarget", quickReset);
+        } finally {
+            await vscode.commands.executeCommand("setContext", "stm32cube-ide-reset.JLinkResetting", false);
+        }
+    }));
+
+    context.subscriptions.push(vscode.commands.registerCommand("st-cube-debug-jlink-gdbserver.reset-target.resetGreyed", () => {
+    }));
+
+    context.subscriptions.push(vscode.commands.registerCommand("st-cube-debug-jlink-gdbserver.number-format.dec", (variable) => setNumberDisplayMode("dec", variable)));
+    context.subscriptions.push(vscode.commands.registerCommand("st-cube-debug-jlink-gdbserver.number-format.hex", (variable) => setNumberDisplayMode("hex", variable)));
+    context.subscriptions.push(vscode.commands.registerCommand("st-cube-debug-jlink-gdbserver.number-format.bin", (variable) => setNumberDisplayMode("bin", variable)));
+}
+
+function registerDebugSessionHooks() {
+    vscode.debug.onDidStartDebugSession((session) => {
+        if (session.configuration?.type === "jlinkgdbtarget") {
+            vscode.commands.executeCommand("setContext", "stm32cube-ide-reset.hasJLinkDebugType", true);
+        }
+    });
+
+    vscode.debug.onDidTerminateDebugSession((session) => {
+        if (session.configuration?.type === "jlinkgdbtarget") {
+            vscode.commands.executeCommand("setContext", "stm32cube-ide-reset.hasJLinkDebugType", false);
+        }
+    });
+
+    vscode.debug.onDidChangeActiveDebugSession((session) => {
+        if (session?.configuration?.type === "jlinkgdbtarget") {
+            vscode.commands.executeCommand("setContext", "stm32cube-ide-reset.hasJLinkDebugType", true);
+        } else {
+            vscode.commands.executeCommand("setContext", "stm32cube-ide-reset.hasJLinkDebugType", false);
+        }
+    });
+}
+
+function activate(context) {
+    registerCommands(context);
+    registerDebugSessionHooks();
+    context.subscriptions.push(vscode.debug.registerDebugConfigurationProvider("jlinkgdbtarget", new JLinkDebugConfigurationProvider(context)));
+}
+
+function deactivate() {
+}

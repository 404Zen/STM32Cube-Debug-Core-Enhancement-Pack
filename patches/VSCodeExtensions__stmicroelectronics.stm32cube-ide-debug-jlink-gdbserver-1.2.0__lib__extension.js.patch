+const vscode = require("vscode");
+const fs = require("fs");
+const path = require("path");
+
+class JLinkDebugConfigurationProvider {
+    constructor(context) {
+        this.context = context;
+    }
+
+    async resolveDebugConfiguration(_folder, config, _token) {
+        if (Object.keys(config).length === 0) {
+            config = this.getInitialConfigurations();
+        }
+        return config;
+    }
+
+    getInitialConfigurations() {
+        const packagePath = path.join(this.context.extensionPath, "package.json");
+        const packageJson = JSON.parse(fs.readFileSync(packagePath, "utf8"));
+        const packageNlsPath = path.join(this.context.extensionPath, "package.nls.json");
+        const packageNls = JSON.parse(fs.readFileSync(packageNlsPath, "utf8"));
+        const initialConfiguration = packageJson.contributes.debuggers.find((debuggerConfig) => debuggerConfig.type === "jlinkgdbtarget")?.initialConfigurations[0];
+        if (!initialConfiguration) {
+            return undefined;
+        }
+        return JSON.parse(
+            JSON.stringify(initialConfiguration),
+            (_key, value) => typeof value === "string"
+                ? value.replace(/%([^%]+)%/g, (match, key) => packageNls[key] ?? match)
+                : value
+        );
+    }
+}
+
+function extractVariableTarget(input) {
+    const candidate = Array.isArray(input) ? input[0] : input;
+    const asText = (value) => typeof value === "string" && value.trim() !== "" ? value.trim() : undefined;
+    if (!candidate) {
+        return undefined;
+    }
+    if (typeof candidate === "string") {
+        const expression = asText(candidate);
+        return expression ? { expression } : undefined;
+    }
+    if (typeof candidate !== "object") {
+        return undefined;
+    }
+    const nestedExpression = typeof candidate.expression === "object" ? candidate.expression : undefined;
+    const nestedVariable = typeof candidate.variable === "object" ? candidate.variable : undefined;
+    const target = {
+        evaluateName: asText(candidate.evaluateName)
+            ?? asText(candidate?.sessionData?.evaluateName)
+            ?? asText(nestedExpression?.evaluateName)
+            ?? asText(nestedVariable?.evaluateName),
+        expression: asText(candidate.expression)
+            ?? asText(candidate?.sessionData?.expression)
+            ?? asText(candidate?.sessionData?.name)
+            ?? asText(nestedExpression?.expression)
+            ?? asText(nestedExpression?.name)
+            ?? asText(nestedVariable?.expression)
+            ?? asText(candidate.id),
+        name: asText(candidate.name)
+            ?? asText(candidate?.sessionData?.name)
+            ?? asText(nestedVariable?.name)
+            ?? asText(candidate.label)
+    };
+    return target.evaluateName || target.expression || target.name ? target : undefined;
+}
+
+function getVariableTargetLabel(target) {
+    return target?.evaluateName ?? target?.expression ?? target?.name ?? "<selected variable>";
+}
+
+async function setNumberDisplayMode(mode, variableInput) {
+    const activeSession = vscode.debug.activeDebugSession;
+    const session = (activeSession?.configuration?.type === "jlinkgdbtarget" ? activeSession : undefined)
+        ?? vscode.debug.sessions.find((item) => item.configuration?.type === "jlinkgdbtarget");
+    if (!session) {
+        vscode.window.showWarningMessage("No active JLink debug session found.");
+        return;
+    }
+    try {
+        const variableTarget = extractVariableTarget(variableInput);
+        if (!variableTarget) {
+            vscode.window.showWarningMessage("No variable context detected. Please right-click a specific variable item.");
+            return;
+        }
+        const modeResponse = await session.customRequest("adapter/setVariableNumberDisplayMode", {
+            mode,
+            target: variableTarget
+        });
+        const normalizedMode = modeResponse?.mode ?? mode;
+        const variableLabel = modeResponse?.variableKey ?? getVariableTargetLabel(variableTarget);
+        vscode.window.showInformationMessage(`Variable ${variableLabel} display mode: ${normalizedMode}`);
+        try {
+            await session.customRequest("adapter/invalidateVariables", {});
+        } catch {
+        }
+    } catch (error) {
+        const message = error instanceof Error ? error.message : String(error);
+        vscode.window.showErrorMessage(`Failed to switch number display mode: ${message}`);
+    }
+}
+
+function registerCommands(context) {
+    context.subscriptions.push(vscode.commands.registerCommand("st-cube-debug-jlink-gdbserver.reset-target.reset", async () => {
+        const session = vscode.debug.activeDebugSession;
+        if (!session) {
+            return;
+        }
+
+        let quickReset = session.configuration?.quickReset;
+        if (quickReset === undefined) {
+            quickReset = [
+                "monitor reset",
+                `tbreak ${session.configuration?.runEntry ?? "main"}`,
+                "continue"
+            ];
+        }
